import re
products = [
    "Laptop",
    "Laptop Bag",
    "Mouse",
    "Wireless Mouse",
    "Keyboard",
    "Gaming Keyboard",
    "Monitor",
    "USB Cable",
    "Phone Charger",
    "Smart Phone"
]

keyword = input("Enter Search Keyword: ")

print("\nExact Match")
exact = [p for p in products if re.fullmatch(keyword, p, re.IGNORECASE)]
print(exact)

print("\nPrefix Match")
prefix = [p for p in products if re.search("^" + re.escape(keyword), p, re.IGNORECASE)]
print(prefix)

print("\nSuffix Match")
suffix = [p for p in products if re.search(re.escape(keyword) + "$", p, re.IGNORECASE)]
print(suffix)

print("\nPartial Match")
partial = [p for p in products if re.search(re.escape(keyword), p, re.IGNORECASE)]
print(partial)

print("\nSearch Report")
print("Exact Matches :", len(exact))
print("Prefix Matches :", len(prefix))
print("Suffix Matches :", len(suffix))
print("Partial Matches :", len(partial))
